#!/usr/bin/env bash
# Install brand assets from a source directory (default: ~/Downloads).
#
# Looks for wireme-logo, wireme-docs-header-logo, wireme-favicon,
# wireme-banner, wireme-banner-light, and github-social-preview as .png or
# .jpg; when several variations exist (browser "(1)" suffixes), the newest
# file wins, so swapping a variation is: regenerate -> rerun this script.
#
# Images that need real transparency (logo, header logo, favicon) are keyed:
# nano banana bakes a fake grey transparency checkerboard into its output,
# so the solid neon strokes are extracted by chroma+brightness masking and
# the glow is re-synthesized cleanly. Inputs that already carry a real alpha
# channel skip the keying. Everything is written as .png to stable paths so
# no reference in the repo ever changes.
#
# Requires ImageMagick (magick).

set -euo pipefail

source_dir="${1:-$HOME/Downloads}"
repository="$(cd "$(dirname "$0")/.." && pwd)"

github_assets="${repository}/.github/assets"
site_assets="${repository}/website/docs/assets"
mkdir -p "${github_assets}" "${site_assets}"

find_asset() {
    # Newest match for "<stem>.<ext>" or "<stem>(N).<ext>" wins.
    local stem="$1" match
    match="$(
        find "${source_dir}" -maxdepth 1 \
            \( -name "${stem}.png" -o -name "${stem}(*).png" \
               -o -name "${stem}.jpg" -o -name "${stem}(*).jpg" \
               -o -name "${stem}.jpeg" -o -name "${stem}(*).jpeg" \) \
            -printf '%T@ %p\n' | sort -rn | head -1 | cut -d' ' -f2-
    )"
    printf '%s' "${match}"
}

has_alpha() {
    magick identify -format '%A' "$1" 2>/dev/null | grep -qiE 'true|blend'
}

key_alpha() {
    # Fake-checkerboard input -> true-alpha PNG with clean synthetic glow.
    local input="$1" output="$2" tmp
    tmp="$(mktemp -d)"

    magick "${input}" \
        \( -clone 0 -colorspace HCL -channel G -separate +channel -level 3%,35% \) \
        \( -clone 0 -colorspace gray -level 48%,80% \) \
        \( -clone 1 -clone 2 -compose Lighten -composite \) \
        -delete 1,2 -alpha off -compose CopyOpacity -composite \
        "${tmp}/keyed.png"

    magick "${tmp}/keyed.png" \
        \( +clone -alpha extract -level 68%,92% -morphology Erode Disk:1 -blur 0x0.6 \) \
        -alpha off -compose CopyOpacity -composite "${tmp}/core.png"

    magick "${tmp}/core.png" \
        -channel RGBA -blur 0x12 -channel A -evaluate multiply 0.6 +channel \
        "${tmp}/glow.png"

    magick "${tmp}/glow.png" "${tmp}/core.png" -compose Over -composite \
        -trim +repage "${output}"

    rm -rf "${tmp}"
}

transparent_asset() {
    # Key when needed, passthrough real-alpha inputs, then trim.
    local input="$1" output="$2"
    if has_alpha "${input}"; then
        magick "${input}" -trim +repage "${output}"
    else
        key_alpha "${input}" "${output}"
    fi
}

opaque_asset() {
    magick "$1" "$2"
}

install_asset() {
    local stem="$1" kind="$2" input
    shift 2
    input="$(find_asset "${stem}")"

    if [ -z "${input}" ]; then
        echo "-- ${stem}: not found in ${source_dir}, skipped"
        return
    fi

    local work
    work="$(mktemp --suffix=.png)"
    "${kind}_asset" "${input}" "${work}"

    local target
    for target in "$@"; do
        cp "${work}" "${target}"
        echo "ok ${stem}: ${input##*/} -> ${target#"${repository}"/}"
    done
    rm -f "${work}"
}

install_asset wireme-logo transparent "${github_assets}/wireme-logo.png"
install_asset wireme-docs-header-logo transparent "${site_assets}/logo.png"
install_asset wireme-banner opaque \
    "${github_assets}/wireme-banner.png" "${site_assets}/wireme-banner.png"
install_asset wireme-banner-light opaque \
    "${github_assets}/wireme-banner-light.png" "${site_assets}/wireme-banner-light.png"
install_asset github-social-preview opaque "${github_assets}/github-social-preview.png"

# Favicon: keyed, squared on a transparent canvas, downscaled.
favicon_input="$(find_asset wireme-favicon)"
if [ -z "${favicon_input}" ]; then
    echo "-- wireme-favicon: not found in ${source_dir}, skipped"
else
    favicon_work="$(mktemp --suffix=.png)"
    transparent_asset "${favicon_input}" "${favicon_work}"
    magick "${favicon_work}" \
        -resize 236x236 -background none -gravity center -extent 256x256 \
        "${site_assets}/favicon.png"
    rm -f "${favicon_work}"
    echo "ok wireme-favicon: ${favicon_input##*/} -> website/docs/assets/favicon.png"
fi

echo "Done. Rebuild the site with: just docs-build"
